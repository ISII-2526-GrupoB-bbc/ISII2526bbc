@page "/purchase/createpurchase"

<h3>CreatePurchase</h3>

@using AppForSEII2526.Web.Components.Shared
@using AppForSEII2526.Web.API
@using Microsoft.AspNetCore.Authorization

@inject NavigationManager navigation
@inject AppForSEII2526APIClient apiclient
@inject ILogger<CreatePurchase> logger
@inject PurchaseStateContainer purchaseState

@* @attribute [Authorize] *@

@* purchase es el DTO que se va a enviar al POST *@
<EditForm Model="purchase" OnValidSubmit="OpenDialog">
    <div class="row">
        <DataAnnotationsValidator />
        <ValidationSummary id="ValidationSummary" class="row alert alert-danger" />
    </div>

    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errores: @messageError</p>
    </div>

    <div class="row g-3">
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="purchase.Name" class="form-control" id="Name" />
                <label for="Name">Nombre de usuario</label>
            </div>
        </div>

        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="purchase.Surname" class="form-control" id="Surname" />
                <label for="Surname">Apellidos</label>
            </div>
        </div>

        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="purchase.Address" class="form-control" id="Address" />
                <label for="Address">Dirección de entrega</label>
            </div>
        </div>
    </div>

    <div class="row g-2">
        <div class="col-md">
            <div class="form-floating">
                <InputSelect class="form-select" @bind-Value="purchase.PaymentMethod" id="PaymentMethod">
                    <option value="@PaymentMethod.CreditCard">CreditCard</option>
                    <option value="@PaymentMethod.PayPal">PayPal</option>
                    <option value="@PaymentMethod.Cash">Cash</option>
                </InputSelect>
                <label for="PaymentMethod">Método de pago</label>
            </div>
        </div>

        <div class="col-md">
            <div class="form-floating">
                <button class="btn btn-primary" type="submit" id="Submit">
                    Comprar coches
                </button>
            </div>
        </div>
    </div>

    <h4>Detalle de la compra</h4>

    <p>
        <b>Precio total:</b> @TotalCost €
        <button class="btn btn-outline-primary" type="button" @onclick="ModifyPurchaseItems" id="ModifyCars">
            Modificar coches
        </button>
    </p>

    <div class="mh-100 table-responsive">
        <table class="table table-condensed table-hover" id="TableOfPurchaseItems">
            <thead>
                <tr>
                    <th>Modelo</th>
                    <th>Color</th>
                    <th>Precio</th>
                    <th>Cantidad</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in purchase.CochesComprados)
                {
                    <tr id="CarData_@item.Id">
                        <td>@item.Model.Name</td>
                        <td>@item.Color</td>
                        <td>@item.PurchasingPrice</td>
                        <td>@item.Quantity</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</EditForm>

@* Diálogo de confirmación *@
@if (DialogIsOpen)
{
    <Dialog Caption="Comprar coches"
            Message="¿Deseas confirmar la compra de los coches seleccionados?"
            OnClose="@OnDialogClose"
            Type="Dialog.Category.SaveNot">
    </Dialog>
}

@code {

    private string messageError = "";
    private bool hideErrors => messageError.Length == 0;
    private bool DialogIsOpen;

    // Accedo al DTO desde el StateContainer
    private ComprarForCreateDTO purchase => purchaseState.Purchase;

    // Calcula el precio total de la compra
    private decimal TotalCost =>
        (decimal) purchase.CochesComprados.Sum(ci => ci.PurchasingPrice * ci.Quantity);

    private void ModifyPurchaseItems()
    {
        // Volver a la pantalla de selección de coches
        navigation.NavigateTo("/purchase/selectcarforpurchase");
    }

    private void OpenDialog()
    {
        DialogIsOpen = true;
    }

    private async Task OnDialogClose(bool isOk)
    {
        DialogIsOpen = false;

        if (!isOk)
            return;

        if (purchase.CochesComprados.Count > 0)
        {
            try
            {
                // Llamada al POST
                var created = await apiclient.CreatePurchaseAsync(purchase);

                // Limpio el estado
                purchaseState.PurchaseProcessed();

                // Navego al detalle
                navigation.NavigateTo($"/purchase/detailpurchase?id={created.Id}");
            }
            catch (ApiException<ValidationProblemDetails> apiValidation)
            {
                messageError = "";
                foreach (var errors in apiValidation.Result.Errors.Values)
                {
                    messageError = string.Join(" (*) ", messageError, string.Join(" (*) ", errors));
                }
            }
            catch (ApiException)
            {
                messageError = "Error al procesar la compra. Inténtelo de nuevo más tarde.";
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // Autorrellenar el nombre de usuario si está autenticado
        if (authenticationState is not null)
        {
            var authState = await authenticationState;
            var user = authState?.User;

            if (user?.Identity?.IsAuthenticated == true)
            {
                purchase.Name = user.Identity.Name;
            }
        }

        // Evito nulls
        purchase.Name ??= "";
        purchase.Surname ??= "";
        purchase.Address ??= "";
    }

    [CascadingParameter]
    private Task<AuthenticationState>? authenticationState { get; set; }
}
