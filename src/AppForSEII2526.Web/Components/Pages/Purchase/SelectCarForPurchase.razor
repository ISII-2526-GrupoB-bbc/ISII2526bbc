@page "/purchase/selectcarforpurchase"

@using AppForSEII2526.Web.API
@inject AppForSEII2526APIClient apiclient
@inject ILogger<SelectCarForPurchase> logger
@inject PurchaseStateContainer purchaseState
@inject NavigationManager navigation

<h3>Seleccionar coche para comprar</h3>

<div class="container-fluid">

    <!-- ERRORES -->
    <div class="row alert alert-danger" hidden="@hideErrors">
        <p>Errores: @errors</p>
    </div>

    <div class="row">

        <!-- PARTE IZQUIERDA -->
        <div class="col-8">

            <!-- FILTROS -->
            <div class="row mb-3">
                <div class="col-4">
                    <input class="form-control"
                           id="ColorFilter"
                           placeholder="Filtrar por color"
                           @bind="colorFilter" />


                </div>

                <div class="col-4">
                    <input class="form-control"
                           id="ModelFilter"
                           placeholder="Filtrar por modelo"
                           @bind="modelFilter" />
                </div>

                <div class="col">
                    <button type="button"
                            id="SearchCarsButton"
                            class="btn btn-primary"
                            @onclick="SearchCars">
                        Buscar coches
                    </button>
                </div>
            </div>

            <!-- RESULTADOS -->
            <div class="row" id="CarsResultZone">
                @if (cars == null)
                {
                    <p>Cargando coches...</p>
                }
                else if (!cars.Any())
                {
                    <p>No se encontraron coches con ese color.</p>
                }
                else
                {
                    <div class="mh-100 table-responsive">
                        <table class="table table-hover" id="CarsTable">

                            <thead>
                                <tr>
                                    <th>Modelo</th>
                                    <th>Fabricante</th>
                                    <th>Color</th>
                                    <th>Combustible</th>
                                    <th>Precio (€)</th>
                                    <th>Añadir</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var car in cars)
                                {
                                    <tr id="CarRow_@car.Id">
                                        <td>@car.ModelName</td>
                                        <td>@car.Manufacturer</td>
                                        <td>@car.Color</td>
                                        <td>@car.FuelType</td>
                                        <td>@car.PurchasingPrice</td>
                                        <td>
                                            <button class="btn btn-outline-secondary"
                                                    id="AddCarButton_@car.Id"
                                                    @onclick="@(() => AddCar(car))">
                                                Añadir
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

        </div>

        <!-- CARRITO -->
        <div class="col-3" id="PurchaseCart" hidden="@hideCart">


            <h4>Carrito de compra</h4>

            @foreach (var item in purchase.CochesComprados)
            {
                <div class="row mb-1">
                    <button class="btn btn-light"
                            id="RemoveCarButton_@item.Id"
                            @onclick="@(() => RemoveItem(item))">
                        x @item.Model - @item.PurchasingPrice€
                    </button>
                </div>
            }

            <div class="row mt-3">
                <strong>Total:</strong> @purchaseState.TotalPrice €
            </div>

            <div class="row mt-3">
                <button class="btn btn-success"
                        id="FinishPurchaseButton"
                        @onclick="GoToPurchase">
                    Finalizar compra
                </button>
            </div>

        </div>

    </div>
</div>

@code {
    private ICollection<CocheParaComprarDTO>? cars;
    private string colorFilter = "";
    private string modelFilter = "";
    private string errors = "";

    private bool hideErrors => errors.Length == 0;

    // alquiler es equivalente a PurchaseForCreateDTO
    private ComprarForCreateDTO purchase => purchaseState.Purchase;

    private bool hideCart => purchase.CochesComprados.Count == 0;




    // BUSCAR COCHES
    public async Task SearchCars()
    {
        try
        {
            errors = "";
            cars = await apiclient.GetCarsAsync(color: colorFilter, model: modelFilter);
        }
        catch (ApiException ex)
        {
            logger.LogError($"{DateTime.Now} Error: {ex}");
            errors = "Error al conectar con el sistema";
        }

        StateHasChanged();
    }


    // AÑADIR AL CARRITO
    private void AddCar(CocheParaComprarDTO car)
    {
        purchaseState.AddCarToPurchase(car);
        StateHasChanged();
    }


    // QUITAR DEL CARRITO
    private void RemoveItem(ComprarForItemDTO item)
    {
        purchaseState.RemovePurchaseItem(item);
        StateHasChanged();
    }


    // IR A LA PÁGINA DE FINALIZAR COMPRA
    private void GoToPurchase()
    {
        navigation.NavigateTo("/purchase/createpurchase");
    }


    // CARGAR AL INICIAR
    protected override async Task OnInitializedAsync()
    {
        await SearchCars();
    }
}
