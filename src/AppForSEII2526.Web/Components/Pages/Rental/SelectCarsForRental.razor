@page "/rental/selectcarsforrental"


@using AppForSEII2526.Web.API
@using Microsoft.AspNetCore.Authorization
@inject AppForSEII2526APIClient apiclient
@inject ILogger<SelectCarsForRental> logger
@inject RentalStateContainer rentalState
@inject NavigationManager navigation

@*@attribute [Authorize]*@

<h3>Select cars for Rental</h3>
<div class="container-fluid">
    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @errors</p>
    </div>
    <div class="row">
        <div class="col-8">
            <div class="row">
                <div class="col">
                    <div class="input-group mb-3">
                        <span class="input-group-text" id="basic-addon1">Model</span>
                        <input type="text" id="modelname" @bind=modelname class="form-control" placeholder="Model" aria-label="Model" aria-describedby="basic-addon1">
                    </div>
                </div>
                <div class="col">
                    <div class="input-group mb-3">
                        <span class="input-group-text" id="basic-addon1">Renting Price</span>
                        <input type="text" id="rentingprice" @bind=rentingprice class="form-control" placeholder="RentingPrice" aria-label="RentingPrice" aria-describedby="basic-addon1">
                    </div>
                </div
                <div class="col">
                    <div class="input-group mb-3">
                        <span class="input-group-text">From</span>
                        <InputDate @bind-Value="@From" id="fromDate" />
                    </div>
                </div>
                <div class="col">
                    <span class="input-group-text">To</span>
                    <InputDate id="toDate" @bind-Value="@To" />
                </div>
                <div class="col">
                    <span class="input-group-text">RentingDate</span>
                    <InputDate id="RentingDate" @bind-Value="@Renting" />
                </div>
                <div class="col">
                    <button type="button" class="btn btn-primary" @onclick=@SearchCars id="searchCars">Search Cars</button>
                </div>



            </div>
            <div class="row">
                @if (cars == null)
                {
                    <p>Loading cars....</p>
                }
                else
                {
                    <div class="mh-100 table-responsive">
                        <table class="table table-condensed table-hover" id="TableOfCars">
                            <thead>
                                <tr>
                                    <th>Model</th>
                                    <th>Fuel Type</th>
                                    <th>Manufacturer</th>
                                    <th>Renting Price</th>
                                    <th>Color</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var car in cars)
                                {
                                    <tr id="CarData_@car.ModelName">
                                        <td>@car.ModelName</td>
                                        <td>@car.FuelType</td>
                                        <td>@car.Manufacturer</td>
                                        <td>@car.RentingPrice</td>
                                        <td>@car.Color</td>
                                        <td>
                                            <button class="btn btn-outline-secondary" id="carToRent_@car.ModelName" @onclick="@(() => AddCar(car))">Add</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                }
            </div>
        </div>
        <div class="col-2" hidden="@hideRentingCart">
            <div class="row">
                <h3>Shopping Cart</h3>
            </div>
            @foreach (RentalItemDTO item in rental.RentalItems)
            {
                <div class="row">
                    <button type="button" class="btn btn-light" id="removeCar_@item.ModelName" @onclick="@(() => RemoveRentalItem(item))">x @item.ModelName - @item.RentingPrice€</button>
                </div>
            }
            <div class="row">
                <button type="button" class="btn btn-primary" id="rentCarButton" @onclick=@RentCars>Rent Cars</button>
            </div>

        </div>
    </div>
</div>

@code {
    private bool hideRentingCart { get { return rental.RentalItems.Count == 0; } }
    private ICollection<CocheParaAlquilarDTO> cars;
    private bool hideErrors { get { return errors.Length == 0; } }
    private string errors = "";
    private string modelname { get; set; }
    private double? rentingprice { get; set; }
    private DateTime _from;
    private DateTime From
    {
        get { return _from; }
        set
        {
            if (_from != value)
            {
                //the rentingcart is cleared to ensure that only cars available for the selected period are selected
                _from = value;
                rental.StartDate = DateTime.SpecifyKind(_from, DateTimeKind.Utc);
                rentalState.ClearRentingCart();
            }
        }
    }

    private DateTime _to;
    private DateTime To
    {
        get { return _to; }
        set
        {
            if (_to != value)
            {
                //the rentingcart is cleared to ensure that only cars available for the selected period are selected
                _to = value;
                rental.EndDate = DateTime.SpecifyKind(_to, DateTimeKind.Utc);
                rentalState.ClearRentingCart();
            }
        }
    }
    private DateTime _renting;
    private DateTime Renting
    {
        get { return _renting; }
        set
        {
            if (_renting != value)
            {
                //the rentingcart is cleared to ensure that only cars available for the selected period are selected
                _renting = value;
                rental.EndDate = DateTime.SpecifyKind(_renting, DateTimeKind.Utc);
                rentalState.ClearRentingCart();
            }
        }
    }

    private RentalForCreateDTO rental => rentalState.Rental;

    private bool hiddenRentingCart = true;

    private void AddCar(CocheParaAlquilarDTO car)
    {
        rentalState.AddCarToRental(car);
    }

    private void RemoveRentalItem(RentalItemDTO item)
    {
        rentalState.RemoveRentalItemToRent(item);
        if (rental.RentalItems.Count == 0) hiddenRentingCart = true;
    }

    public async void SearchCars()
    {
        if (rental.StartDate > rental.EndDate)
        {
            errors = "Your rental must end after than its starts";
            return;
        }

        if (rental.StartDate < DateTime.Today || rental.EndDate < DateTime.Today)
        {
            errors = "Your rental period must be later";
            return;
        }
        try
        {
            cars = await apiclient.GetCarsRentalAsync(rentingprice, modelname);
            errors = "";
        }
        catch (ApiException ex)
        {
            logger.LogError($"{DateTime.Now} Error: {ex}");
            errors = "Error while connecting to the system";
        }
        StateHasChanged();
    }

    protected override Task OnInitializedAsync()
    {
        //the type of RentalDateFrom is DateTimeOffset, it is required a conversion
        _from = (_from == new DateTime(1, 1, 1)) ?
            DateTime.SpecifyKind(DateTime.Today.AddDays(1), DateTimeKind.Utc)
            : _from;
        rental.StartDate = _from;
        //the type of RentalDateFrom is DateTimeOffset, it is required a conversion

        _to = (_to == new DateTime(1, 1, 1)) ?
            DateTime.SpecifyKind(DateTime.Today.AddDays(2), DateTimeKind.Utc)
            : _to;
        rental.EndDate = _to;

        _renting = (_renting == new DateTime(1, 1, 1)) ?
            DateTime.SpecifyKind(DateTime.Today.AddDays(2), DateTimeKind.Utc)
            : _renting;
        rental.RentingDate = _renting;

        SearchCars();

        return base.OnInitializedAsync();
    }
    private void RentCars()
    {
        navigation.NavigateTo("/rental/post");
    }
}
