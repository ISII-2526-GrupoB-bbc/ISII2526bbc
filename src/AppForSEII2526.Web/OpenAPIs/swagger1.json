  "components": {
    "schemas": {
      "CocheParaAlquilarDTO": {
        "required": [
          "color",
          "fuelType",
          "manufacturer",
          "modelName",
          "rentingPrice"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "modelName": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "color": {
            "maxLength": 30,
            "minLength": 0,
            "type": "string"
          },
          "fuelType": {
            "minLength": 1,
            "type": "string"
          },
          "manufacturer": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "rentingPrice": {
            "maximum": 200000,
            "minimum": 0,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "CocheParaComprarDTO": {
        "required": [
          "color",
          "fuelType",
          "id",
          "manufacturer",
          "modelName",
          "purchasingPrice"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "modelName": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "color": {
            "maxLength": 30,
            "minLength": 0,
            "type": "string"
          },
          "fuelType": {
            "minLength": 1,
            "type": "string"
          },
          "manufacturer": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "purchasingPrice": {
            "maximum": 200000,
            "minimum": 0,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "CocheParaReviewDTO": {
        "required": [
          "carClass",
          "color",
          "fuelType",
          "id",
          "manufacturer",
          "modelName"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "modelName": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "color": {
            "maxLength": 30,
            "minLength": 0,
            "type": "string"
          },
          "fuelType": {
            "minLength": 1,
            "type": "string"
          },
          "manufacturer": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "carClass": {
            "maxLength": 30,
            "minLength": 0,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ComprarForCreateDTO": {
        "required": [
          "address",
          "cochesComprados",
          "name",
          "paymentMethod",
          "surname"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 50,
            "minLength": 2,
            "type": "string"
          },
          "surname": {
            "maxLength": 80,
            "minLength": 2,
            "type": "string"
          },
          "address": {
            "maxLength": 100,
            "minLength": 10,
            "type": "string"
          },
          "paymentMethod": {
            "$ref": "#/components/schemas/PaymentMethod"
          },
          "cochesComprados": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ComprarForItemDTO"
            }
          },
          "TotalPrice": {
            "type": "number",
            "format": "double",
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "ComprarForDetailDTO": {
        "required": [
          "address",
          "cochesComprados",
          "id",
          "name",
          "paymentMethod",
          "purchasingDate",
          "surname"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 50,
            "minLength": 2,
            "type": "string"
          },
          "surname": {
            "maxLength": 80,
            "minLength": 2,
            "type": "string"
          },
          "address": {
            "maxLength": 100,
            "minLength": 10,
            "type": "string"
          },
          "paymentMethod": {
            "$ref": "#/components/schemas/PaymentMethod"
          },
          "cochesComprados": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ComprarForItemDTO"
            }
          },
          "TotalPrice": {
            "type": "number",
            "format": "double",
            "readOnly": true
          },
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "purchasingDate": {
            "type": "string",
            "format": "date-time"
          },
          "quantityForPurchasing": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "ComprarForItemDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "model": {
            "$ref": "#/components/schemas/Model"
          },
          "color": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "purchasingPrice": {
            "type": "number",
            "format": "double"
          },
          "quantity": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "Model": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "PaymentMethod": {
        "enum": [
          "CreditCard",
          "PayPal",
          "Cash"
        ],
        "type": "string"
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "detail": {
            "type": "string",
            "nullable": true
          },
          "instance": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": { }
      },
      "RentalDetailDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "customerName": {
            "type": "string",
            "nullable": true
          },
          "customerSurname": {
            "type": "string",
            "nullable": true
          },
          "deliveryCarDealer": {
            "type": "string",
            "nullable": true
          },
          "paymentMethod": {
            "$ref": "#/components/schemas/PaymentMethod"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "rentingDate": {
            "type": "string",
            "format": "date-time"
          },
          "rentingPrice": {
            "type": "number",
            "format": "double"
          },
          "rentalItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RentalItemDTO"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
